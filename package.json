{
	"name": "kogu",
	"version": "0.0.6",
	"description": "Kogu - A collection of useful developer tools (小道具 - props for developers)",
	"type": "module",
	"author": "seijikohara",
	"keywords": [
		"developer-tools",
		"utilities",
		"kogu",
		"小道具"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/seijikohara/kogu"
	},
	"scripts": {
		"prepare": "lefthook install",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && bun run validate:pages",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"validate:pages": "bun run scripts/validate-pages.ts",
		"build:sidecar": "bun run scripts/build-sidecar.ts",
		"build:sidecar:release": "bun run scripts/build-sidecar.ts --release",
		"tauri": "tauri",
		"tauri:dev": "bun run build:sidecar && tauri dev --no-watch",
		"tauri:build": "bun run build:sidecar:release && tauri build",
		"release": "bun run scripts/release.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"deps:check": "bunx taze",
		"deps:check:backend": "cargo install cargo-edit -q && cd src-tauri && cargo upgrade --dry-run",
		"deps:update": "bunx taze major -r -w && bun install",
		"deps:update:backend": "cargo install cargo-edit -q && cd src-tauri && cargo upgrade --incompatible --exclude ipnetwork --exclude rand --exclude snmp2 && cargo update",
		"deps:update:all": "bun run deps:update && bun run deps:update:backend"
	},
	"license": "MIT",
	"dependencies": {
		"@hpcc-js/wasm-graphviz": "^1.21.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "4.2.4",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.7.0",
		"@tauri-apps/plugin-fs": "^2.5.0",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-window-state": "^2",
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-mention": "^3.22.4",
		"@tiptap/extension-subscript": "^3.22.4",
		"@tiptap/extension-superscript": "^3.22.4",
		"@tiptap/extension-typography": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@viz-js/viz": "^3.26.0",
		"@vizel/core": "^1.3.1",
		"@vizel/svelte": "^1.3.1",
		"@xml-tools/ast": "^5.0.5",
		"@xml-tools/parser": "^1.0.11",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"crypto-js": "^4.2.0",
		"fuse.js": "^7.3.0",
		"json5": "^2.2.3",
		"jsonc-parser": "^3.3.1",
		"katex": "^0.16.45",
		"lowlight": "^3.3.0",
		"markdown-it": "^14.1.1",
		"markdown-it-texmath": "^1.0.0",
		"mermaid": "^11.14.0",
		"monaco-editor": "^0.55.1",
		"monaco-yaml": "^5.4.1",
		"node-sql-parser": "^5.4.0",
		"sql-formatter": "^15.7.3",
		"tailwindcss": "4.2.4",
		"xml-formatter": "^3.7.0",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/crypto-js": "^4.2.2",
		"@types/katex": "^0.16.8",
		"@types/markdown-it": "^14.1.2",
		"bits-ui": "^2.18.0",
		"bun-types": "^1.3.13",
		"clsx": "^2.1.1",
		"jsdom": "^29.0.2",
		"lefthook": "^2.1.6",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.9",
		"vite-plugin-monaco-editor": "^1.1.0",
		"vitest": "^4.1.4"
	},
	"overrides": {
		"ajv": "8.18.0",
		"@tiptap/core": "^3.22.4",
		"@tiptap/pm": "^3.22.4"
	}
}
