{
	"name": "kogu",
	"version": "0.0.6",
	"description": "Kogu - A collection of useful developer tools (小道具 - props for developers)",
	"type": "module",
	"author": "seijikohara",
	"keywords": [
		"developer-tools",
		"utilities",
		"kogu",
		"小道具"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/seijikohara/kogu"
	},
	"scripts": {
		"prepare": "lefthook install",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "bun run build:tokens && tsc --noEmit && bun run validate:pages && bun run audit:design",
		"build:tokens": "bun run scripts/build-tokens.ts",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"validate:pages": "bun run scripts/validate-pages.ts",
		"audit:design": "bun run scripts/audit-design.ts",
		"build:sidecar": "bun run scripts/build-sidecar.ts",
		"build:sidecar:release": "bun run scripts/build-sidecar.ts --release",
		"tauri": "tauri",
		"tauri:dev": "bun run build:sidecar && tauri dev --no-watch",
		"tauri:build": "bun run build:sidecar:release && tauri build",
		"release": "bun run scripts/release.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"deps:check": "bunx taze",
		"deps:check:backend": "cargo install cargo-edit -q && cd src-tauri && cargo upgrade --dry-run",
		"deps:update": "bunx taze major -r -w && bun install",
		"deps:update:backend": "cargo install cargo-edit -q && cd src-tauri && cargo upgrade --incompatible && cargo update",
		"deps:update:all": "bun run deps:update && bun run deps:update:backend"
	},
	"license": "MIT",
	"dependencies": {
		"@faker-js/faker": "^10.4.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@hpcc-js/wasm-graphviz": "^1.21.5",
		"@peculiar/x509": "^2.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "4.3.0",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-fs": "^2.5.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-window-state": "^2.4.1",
		"@tiptap/core": "^3.23.4",
		"@tiptap/extension-mention": "^3.23.4",
		"@tiptap/extension-subscript": "^3.23.4",
		"@tiptap/extension-superscript": "^3.23.4",
		"@tiptap/extension-typography": "^3.23.4",
		"@tiptap/pm": "^3.23.4",
		"@tiptap/react": "^3.23.4",
		"@tiptap/suggestion": "^3.23.4",
		"@visx/axis": "^3.12.0",
		"@visx/grid": "^3.12.0",
		"@visx/group": "^3.12.0",
		"@visx/responsive": "^3.12.0",
