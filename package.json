		"@xml-tools/parser": "^1.0.11",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"class-variance-authority": "^0.7.1",
		"cmdk": "^1.1.1",
		"cron-parser": "^5.5.0",
		"cronstrue": "^3.14.0",
		"date-fns": "^4.3.0",
		"exifr": "^7.1.3",
		"fuse.js": "^7.3.0",
		"js-md5": "^0.8.3",
		"jschardet": "^3.1.4",
		"json5": "^2.2.3",
		"jsonc-parser": "^3.3.1",
		"katex": "^0.17.0",
		"lowlight": "^3.3.0",
		"lucide-react": "^1.16.0",
		"markdown-it": "^14.1.1",
